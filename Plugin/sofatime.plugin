#!name=优化Trakt简体中文体验 + SenPlayer
#!desc=翻译Trakt首页列表，优先简体中文；历史只显示最新一集；Trakt & SofaTime 添加 EplayerX、Forward、Infuse、SenPlayer 跳转
#!icon=https://app.trakt.tv/pwa/android/icon_192.png
#!author=DemoJameson + 魔改SenPlayer

[Argument]
latestHistoryEpisodeOnly = switch, "true", tag=历史剧集只显示最新一集
commentTranslationEnabled = switch, "true", tag=翻译评论
backendBaseUrl = input, "https://loon-plugins.demojameson.de5.net", tag=翻译API

[Script]
# 手动清理缓存
cron "0 0 1 1 1" script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese_clear_cache.js, timeout=10, enable=false, tag=清理本地缓存

# 核心脚本（本地注入SenPlayer）
http-request ^https:\/\/loon-plugins\.demojameson\.de5\.net\/api\/redirect script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, tag=Direct Redirect
http-request ^https:\/\/image\.tmdb\.org\/t\/p\/w342\/[a-z0-9_-]+_logo\.webp script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, tag=TMDB Logo Redirect

# 以下全部走远程JS，但已在内部追加SenPlayer
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/settings script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt User Settings
http-response ^https:\/\/apiz?\.trakt\.tv\/.+\/translations\/zh script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt Translations
http-response ^https:\/\/apiz?\.trakt\.tv\/sync\/progress\/up_next_nitro script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt Up Next
http-response ^https:\/\/apiz?\.trakt\.tv\/sync\/playback\/movies script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt Playback Movies
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/me\/watchlist\/(shows|movies)\/released script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt Watchlist Released

# Sofa Time 播放器注入（已包含SenPlayer）
http-response ^https:\/\/api\.themoviedb\.org\/3\/watch\/providers\/(movie|tv) script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=TMDB Provider Catalog
http-response ^https:\/\/streaming-availability\.p\.rapidapi\.com\/shows\/tt\d+ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Sofa Time Detail
http-response ^https:\/\/streaming-availability\.p\.rapidapi\.com\/countries\/[a-z]{2} script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Sofa Time Country

# 日历 & 历史 & 收藏
http-response ^https:\/\/apiz?\.trakt\.tv\/calendars\/my\/(shows|movies) script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt Calendar
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+\/history script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt History
http-response ^https:\/\/apiz?\.trakt\.tv\/sync\/history script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Trakt Sync History

# 剧集历史只显示最新一集
http-request ^https:\/\/apiz?\.trakt\.tv\/(users\/[^\/]+\/history|sync)\/episodes script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=History Episodes Request
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+\/history\/episodes script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=History Episodes Response

# 电影历史
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+\/history\/movies script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=History Movies

# 片单、关注、动态、榜单
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+\/collection\/media script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Collection
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/me\/following\/activities script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Following Activities
http-response ^https:\/\/apiz?\.trakt\.tv\/(users\/[^\/]+\/lists|lists)\/\d+\/items script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=List Items
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+\/favorites script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Favorites
http-response ^https:\/\/apiz?\.trakt\.tv\/media\/(trending|recommendations|anticipated|popular\/next) script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Media Lists
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/me\/watchlist script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Watchlist

# 季、剧集、详情页
http-request ^https:\/\/apiz?\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Current Season
http-response ^https:\/\/apiz?\.trakt\.tv\/shows\/[^\/]+\/seasons script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Seasons List
http-response ^https:\/\/apiz?\.trakt\.tv\/(shows|movies)\/[^\/]+ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Media Detail
http-response ^https:\/\/apiz?\.trakt\.tv\/people\/[^\/]+ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=People Detail
http-response ^https:\/\/apiz?\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+\/episodes\/\d+ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Episode Detail

# WatchNow 播放器注入（关键：已加入SenPlayer）
http-response ^https:\/\/apiz?\.trakt\.tv\/watchnow\/sources script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Watchnow Sources
http-response ^https:\/\/apiz?\.trakt\.tv\/(movies|shows|episodes)\/[^\/]+\/watchnow script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Watchnow

# 评论翻译
http-response ^https:\/\/apiz?\.trakt\.tv\/(shows|movies)\/[^\/]+\/comments script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Comments
http-response ^https:\/\/apiz?\.trakt\.tv\/comments\/\d+\/replies script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Comment Replies
http-response ^https:\/\/apiz?\.trakt\.tv\/v3\/media\/(movie|show)\/\d+\/info\/\d+\/version\/\d+ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Sentiments
http-response ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+\/mir script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{backendBaseUrl}], tag=Month in Review

[MITM]
hostname = apiz.trakt.tv, api.trakt.tv, api.themoviedb.org, image.tmdb.org, streaming-availability.p.rapidapi.com, loon-plugins.demojameson.de5.net
